generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum CampaignStatus {
  DRAFT
  GENERATING
  READY
  LAUNCHED
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String
  password         String?
  plan             Plan       @default(FREE)
  stripeCustomerId String?
  emailVerified    Boolean    @default(false)
  verifyToken      String?    @unique
  metaAccessToken  String?
  metaAdAccountId  String?
  spotifyArtistId   String?
  spotifyArtistName String?
  /// Crédits export vidéo (1 crédit = 1 génération). Défaut 1 à l’inscription.
  videoCredits     Int        @default(1)
  campaigns        Campaign[]
  tracks           Track[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

/// Morceaux du catalogue public Spotify synchronisés pour l’artiste lié au compte.
model Track {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyTrackId  String
  name            String
  artistName      String
  albumName       String
  albumImageUrl   String?
  durationMs      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, spotifyTrackId])
}

model Campaign {
  id             String         @id @default(cuid())
  /// Null tant que brouillon anonyme (sessionId) ; renseigné à la génération ou liaison compte.
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Brouillon créé sans compte ; fusionné au userId au moment de la génération.
  sessionId      String?
  trackTitle     String
  artistName     String
  spotifyTrackId String?
  trackS3Key     String?
  trackUrl       String?
  hookStart      Float?
  hookEnd        Float?
  videoS3Key     String?        // source video: custom upload S3 key
  videoUrl       String?        // source video: stock URL or custom upload URL
  editorSettings Json?          // filter, text, fade settings
  status         CampaignStatus @default(DRAFT)
  metaCampaignId String?
  generatedAd    GeneratedAd?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([sessionId])
}

model GeneratedAd {
  id         String   @id @default(cuid())
  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  videoS3Key String?
  videoUrl   String?
  metaAdId   String?
  createdAt  DateTime @default(now())
}
